{% block content %}

<div class="item">
    <div>Nome</div>
    <div>
        <input 
            type="text" 
            name="name" 
            value="{{chef.name}}"
        >
    </div>
</div>

<div class="item">
    <div>Avatar</div>
    <div id="photos-upload">
        <input 
            id='input-file' 
            type='file' 
            name="photos" 
            accept="image/*"
            onchange="PhotosUpload.handleImageInput(event)"
        >
    </div>

     <label 
        class="send-avatar" 
        for='input-file'>
        Enviar Avatar
    </label>
</div>

{% endblock content %}

