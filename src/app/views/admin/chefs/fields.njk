{% block content %}

<div class="item">
        <div>Nome</div>
    <div>
        <input 
            type="text" 
            name="name" 
            value="{{chef.name_chef}}"
        >
    </div>
</div>
</div> 
 
<div class="item">
    <label for="">Avatar</label>
    <div id="photos-upload-chef">
            <p>Enviar Avatar</p>
            <input 
            id="photos-input"
            type="file" 
            name="photos" 
            multiple
            accept="image/*"
            onchange="PhotosUpload.handleFileInput(event)"
            >
        </div>
</div> 

{% endblock content %}
