{% extends "session-layout.njk" %}
{% block content %}
<main>
<form class="login details" method="POST" action="">
    <div class="subtitulo">
        <h2>Esqueceu a Senha?</h2>
    </div>
    <div class="item">
        <div>Email</div>
            <div class="input">
                <input 
                    type="email" 
                    name="email"
                    placeholder="Digite seu email para recuperar sua senha" 
                    value="{{ user.email }}" 
                    onblur="Validate.apply(this, 'isEmail')"
                >
            </div>
        </div>
    </div>
        
    <div class="footer">
      <div class="btn-Recuperar"> 
        <button type="submit">Recupera</button>
      </div>   
    </div>
</form>
</main>
{% endblock %}