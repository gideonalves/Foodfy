{% extends "session-layout.njk" %}
{% block content %}
<main>
<form class="login details" method="POST" action="/admin/login">
    <div class="subtitulo">
        <h2>Iniciar Sessão</h2>
    </div>
    <div class="item">
        <div>Email</div>
            <div class="input">
                <input 
                    type="email" 
                    name="email"
                    value="{{ user.email }}" 
                    placeholder="Digite seu email" 
                    onblur="Validate.apply(this, 'isEmail')"
                >
            </div>
        </div>
        <div class="item">
            <div>Senha</div>
            <div class="input">
                <input 
                    type="password" 
                    name="password" 
                    placeholder="Digite sua senha"
                >
            </div>
            </div>
            <div class="footer">
                <a href="/admin/forgot-password">Perdeu a senha?</a>         
                <button type="submit">Acessar</button>
            </div>
        </form>
    </main>
{% endblock %}