{% extends "session-layout.njk" %}
{% block content %}
<main>
<form class="login details" method="POST" action="/admin/password-reset">
    <div class="subtitulo">
        <h2>Nova senha</h2>
    </div>
    
         <div class="item">
            <label>E-mail</label>
            <div class="input">
               <input 
                  type="email" 
                  name="email" 
                  placeholder="Digite o email" 
                  value="{{ user.email }}" 
                  onblur="Validate.apply(this, 'isEmail')" 
                  required
               >
            </div>
         </div>

         <div class="item">
            <label>Nova senha</label>
            <div class="input">
               <input 
                  type="password" 
                  name="password" 
                  placeholder="Digite sua nova senha"
               >
            </div>
         </div>

         <div class="item">
            <label>Repetir senha</label>
            <div class="input">
               <input 
                  type="password" 
                  name="passwordRepeat" 
                  placeholder="Repita a nova senha"
               >
            </div>

         </div>
         
         <input type="hidden" name="token" value="{{token}}">
 


    <div class="footer">
      <div class="btn-Recuperar"> 
        <button type="submit">Nova Senha</button>
      </div>   
    </div>
</form>
</main>
{% endblock %}